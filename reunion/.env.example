# ============================
# 同窓会管理アプリ 設定ファイル
# ============================
# このファイルをコピーして .env という名前で保存し、実際の値を入力してください
# cp .env.example .env

# --- アプリ設定 ---
SECRET_KEY=change-me-to-random-string-please
FLASK_ENV=development

# --- データベース ---
# デフォルトは instance/reunion.db（変更不要）
# DATABASE_URL=sqlite:///reunion.db

# --- メール設定 ---
# MAIL_MODE=console   ... コンソール出力（開発環境・実送信しない）
# MAIL_MODE=smtp      ... SMTPで実際に送信
# MAIL_MODE=brevo     ... Brevo APIで送信（推奨）
MAIL_MODE=console

# Brevo設定（MAIL_MODE=brevo の場合のみ必要）
BREVO_API_KEY=your-brevo-api-key
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=同窓会幹事

# SMTP設定（MAIL_MODE=smtp の場合のみ必要）
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=your-email@gmail.com
MAIL_SMTP_PASSWORD=your-app-password

# --- アプリURL（本出欠メールに使用） ---
# ローカル実行時はそのままでOK
APP_BASE_URL=http://localhost:5000

# --- 同窓会情報（メール本文に使用） ---
REUNION_NAME=〇〇年度同窓会
REUNION_DATE=2025年XX月XX日
REUNION_TIME=XX時〜XX時
REUNION_VENUE=〇〇ホテル
REUNION_FEE=10000
DRESS_CODE=平服
BELONGINGS=

# --- 振込先情報（メール本文に使用） ---
TRANSFER_BANK=〇〇銀行
TRANSFER_BRANCH=〇〇
TRANSFER_BRANCH_NUMBER=123
TRANSFER_ACCOUNT_TYPE=普通
TRANSFER_ACCOUNT_NUMBER=1234567
TRANSFER_ACCOUNT_NAME=ドウソウカイ
TRANSFER_DEADLINE=〇月〇日
